rules_version = '2';

// MarketWar OS Firestore rules — deny by default.
// Server-side writes (Next.js API routes on Vercel via the Admin SDK) bypass
// these rules; they govern direct client access only. As client features
// (auth, real-time dashboards) come online, open access per-collection with
// owner checks — never with a blanket allow.
service cloud.firestore {
  match /databases/{database}/documents {

    // Tenant-scoped data: a signed-in user may only touch their own tenant.
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.tenantId == tenantId;
    }

    // users (v3.0 spec 6.2.1): owner-only reads. All writes go through
    // backend services via the Admin SDK (auth/billing/MOA), so client
    // writes are denied entirely — enforcing "write: service only".
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // businesses (v3.0 spec 6.2.2): owner full access; agency admins of the
    // same agency may read. BVI/diagnostic fields are service-written.
    match /businesses/{businessId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.token.role == 'agency_admin');
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // brands (multi-tenant isolation): the ownership record claimed on first use
    // by src/backend/brand-access.ts. The owner may READ their own brand record;
    // ALL writes (claim, transfer) go through the Admin SDK server-side so a
    // client can never re-assign ownership. This is the database-level backstop
    // to the server guard — even a direct client request cannot read another
    // brand's ownership record or forge a claim.
    match /brands/{brandId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }
    // Per-brand settings are written AND read only through the Admin SDK (the
    // /api/settings route, which now enforces brand ownership). No direct client
    // access. (The results ledger is likewise server-only — see /results below.)
    match /settings/{doc} {
      allow read, write: if false;
    }

    // Server-written analytics/logs: clients may never read or write.
    match /audits/{doc} {
      allow read, write: if false;
    }
    match /agent_runs/{doc} {
      allow read, write: if false;
    }
    // Attributed-revenue ledger (results): written ONLY by the Admin SDK
    // (manual log, owned-form capture, Stripe webhook). No client access — the
    // dashboard reads via /api/results, which is server-side. Append-only in
    // spirit; the id is the source event id so redelivery never double-counts.
    match /results/{doc} {
      allow read, write: if false;
    }

    // ── ModelGate / commercial core (production architecture §20, §22, §35) ──
    // The client may READ authorised business data but must NEVER directly
    // modify balances, costs, subscriptions, model pricing, margins, security
    // or audit history — those writes occur only through trusted Admin SDK
    // operations (rule #17: block direct balance manipulation).
    function isOrgMember(orgId) {
      return request.auth != null && request.auth.token.organisationId == orgId;
    }

    // ACU ledger + wallets: organisation members read; writes are server-only.
    match /acuWallets/{walletId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /acuTransactions/{txId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false; // append-only ledger, Admin SDK only
    }
    match /acuReservations/{resId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    // AI jobs + generated assets: org members read their own; writes server-only.
    match /aiJobs/{jobId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /generatedAssets/{assetId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    // Subscriptions + billing events: read own org; writes only via Stripe
    // webhook / Admin SDK (never the client).
    match /subscriptions/{subId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /billingEvents/{evId} {
      allow read, write: if false; // server-only
    }
    // Model registry + provider health/pricing: public-readable catalogue
    // (no secrets, no prices client-side), admin-written only.
    match /providerModels/{modelId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /providerHealth/{providerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Margins, provider costs, security + audit: never client-accessible.
    match /marginRecords/{doc} { allow read, write: if false; }
    match /providerUsage/{doc} { allow read, write: if false; }
    match /providerCosts/{doc} { allow read, write: if false; }
    match /securityEvents/{doc} { allow read, write: if false; }
    match /auditLogs/{doc} { allow read, write: if false; }

    // ── Creator & Partner Monetisation Engine (src/backend/creator-engine.ts) ──
    // Money-bearing collections: partner accounts, subscriptions, the append-only
    // conversion ledger, payout records, and the raw applications (PII). ALL are
    // written AND read only through the Admin SDK. A partner reads their own data
    // through the token-gated /api/creator-engine `partner_portal` action (their
    // access token is the credential) — never by direct client Firestore access.
    // Brands manage programmes through the ownership-checked API. So every one of
    // these is deny-all at the database layer: no client can read another
    // partner's earnings/PII or forge a conversion, cap release, or payout.
    match /creator_accounts/{doc} { allow read, write: if false; }
    match /creator_programmes/{doc} { allow read, write: if false; }
    match /creator_subscriptions/{doc} { allow read, write: if false; }
    match /creator_ledger/{doc} { allow read, write: if false; }
    match /creator_payouts/{doc} { allow read, write: if false; }
    match /partner_applications/{doc} { allow read, write: if false; }

    // Collaboration & Approvals (src/backend/approvals.ts): brand-scoped review
    // items + immutable history. Read/write only via the ownership-checked
    // /api/approvals route (Admin SDK). No direct client access.
    match /approval_items/{doc} { allow read, write: if false; }

    // Sending-domain authentication (src/backend/sending-domains.ts): per-brand
    // DKIM keypairs + verification state. Holds PRIVATE signing keys, so it is
    // deny-all at the DB layer — created, read (public half only) and verified
    // exclusively through the ownership-checked /api/sending-domains route (Admin
    // SDK). No client ever reads a private key.
    match /sending_domains/{doc} { allow read, write: if false; }

    // Email templates (src/backend/email-templates.ts): per-brand reusable
    // templates. Read/written only through the ownership-checked
    // /api/email-templates route (Admin SDK). No direct client access.
    match /email_templates/{doc} { allow read, write: if false; }

    // Email delivery events + suppression ledger (src/backend/email-events.ts):
    // opens/clicks/bounces/complaints/unsubscribes and the do-not-send list.
    // Written by tracking pixels/redirects + the secret-gated webhook; read via
    // the ownership-checked stats route. All Admin-SDK only — deny-all here.
    match /email_events/{doc} { allow read, write: if false; }
    match /email_suppressions/{doc} { allow read, write: if false; }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
