# MarketWar OS — environment configuration
# Copy to .env.local and fill in your own keys. NEVER commit real keys.

# ── AI Gateway ───────────────────────────────────────────────────────────
# The gateway routes every agent call through the first configured provider
# and fails over to the next on errors. With no keys set the platform runs
# in Demo Intelligence mode (deterministic simulated output).

# Provider order (comma-separated: anthropic, openai, gemini)
AI_GATEWAY_ORDER=anthropic,openai,gemini

# Anthropic Claude (primary)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (failover)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Google Gemini (failover)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Image Generation Gateway ─────────────────────────────────────────────
# Multi-provider image engine (src/backend/image-gateway.ts). With no keys the
# zero-config Demo Composer renders brand-safe SVG creatives. Live providers
# activate per key: Gemini Nano Banana 2/Pro reuse GEMINI_API_KEY above;
# OpenAI GPT Image 2 reuses OPENAI_API_KEY above; Black Forest Labs FLUX.2:
BFL_API_KEY=
# Optional Vertex AI (service-account JSON path — file, never committed):
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=

# ── Real-Time Search & Opportunity Intelligence (optional accelerator) ────
# Serper.dev live Google data (Search/News/Places/Shopping/Images). Without it
# the search layer returns structured demo results — the OS stays fully useful.
SERPER_API_KEY=
# Optional B2B data provider for the LeadWar Room prospecting engine. Without a
# key the engine returns compliant deterministic demo prospects.
APOLLO_API_KEY=

# ── Firebase (backend: Auth, Firestore, Storage) ─────────────────────────
# Optional — without these the platform runs with no persistence (demo mode).
# Project: MarketWar (studio-1718252475-c6017). The public identifiers below
# are non-secret app config. The web API key is NOT committed here per repo
# policy — set NEXT_PUBLIC_FIREBASE_API_KEY in .env.local / Vercel env yourself
# (Firebase console → Project settings → Your apps). It is a public web key, but
# we keep keys out of source control and rely on Firebase Security Rules +
# App Check for protection.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=studio-1718252475-c6017.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-1718252475-c6017
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studio-1718252475-c6017.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=221113093533
NEXT_PUBLIC_FIREBASE_APP_ID=1:221113093533:web:26a80dc041406d66dc3374
# Realtime Database instance (region europe-west1 → EU data residency). RTDB is
# intentionally unused (locked deny-all in database.rules.json); wired only for
# completeness — the OS uses Firestore.
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://studio-1718252475-c6017-default-rtdb.europe-west1.firebasedatabase.app
# Admin SDK (from a service-account key — server-side only, never public):
FIREBASE_PROJECT_ID=studio-1718252475-c6017
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@studio-1718252475-c6017.iam.gserviceaccount.com
# The private key is a SECRET — generate a service-account key in the Firebase
# console and set it here (with literal \n for newlines). Never commit it.
FIREBASE_PRIVATE_KEY=

# ── Stripe (subscriptions + ACU top-ups) ─────────────────────────────────
# Webhook endpoint: https://marketwaros.com/api/webhooks/stripe
# Set the signing secret from Stripe dashboard → Developers → Webhooks. Without
# it the endpoint runs in demo mode (signature NOT enforced — never in prod).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email delivery (transactional + lifecycle sends) ─────────────────────
# The email engine (src/backend/email.ts) tries providers in order: SMTP
# first, then the Resend and SendGrid HTTP APIs. With none configured it runs
# in demo mode (sends are simulated, nothing leaves the machine).
#
# SMTP — the go-live path. Point these at your relay (Brevo, Postmark, SES,
# Mailgun, etc.). Port 465 = implicit TLS; 587 = STARTTLS (set SMTP_SECURE=true
# to force implicit TLS on a non-465 port). Credentials are server-side secrets
# — never commit real values.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# The From identity for all platform mail. Use a subdomain you control and have
# authenticated with SPF + DKIM + DMARC for inbox placement.
EMAIL_FROM=MarketWar OS <os@notifications.marketwaros.com>
# Optional HTTP fallbacks (used only if SMTP is unset or fails):
RESEND_API_KEY=
SENDGRID_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────
# Production domain: https://marketwaros.com (Hostinger DNS → Vercel).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCTION_URL=https://marketwaros.com
