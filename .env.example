# MarketWar OS — environment configuration
# Copy to .env.local and fill in your own keys. NEVER commit real keys.

# AI provider (optional). Without a key the platform runs in Demo Intelligence
# mode with deterministic simulated agent output.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Base URL used in generated links
NEXT_PUBLIC_APP_URL=http://localhost:3000
