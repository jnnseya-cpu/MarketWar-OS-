# MarketWar OS sending node (docker-mailserver).
#
# The compose file hard-codes hostname: smtp.marketwaros.com — change it there
# and in your DNS if your sending host differs.
#
# There is NO account password in this file: the submission account is created
# after `docker compose up -d` with
#   docker exec -it mailserver setup email add appuser@marketwaros.com '<pass>'
# and that address + password become the APP's env vars:
#   SMTP_HOST=smtp.marketwaros.com
#   SMTP_PORT=587
#   SMTP_USER=appuser@marketwaros.com
#   SMTP_PASS=<pass>
#   SMTP_SECURE=false
