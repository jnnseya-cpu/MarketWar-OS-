# MarketWar OS sending node — config for docker-compose.yml.
# Copy to .env and fill in. NEVER commit the real .env.

# The node's public hostname. MUST match the A record (hostname -> IP) and the
# PTR/reverse DNS (IP -> hostname). Forward and reverse must agree.
MYHOSTNAME=smtp.marketwaros.com

# The submission account the app authenticates as. These MUST equal the app's
# SMTP_USER / SMTP_PASS env vars. Use a long random password.
SMTP_USER=appuser@smtp.marketwaros.com
SMTP_PASS=change-me-to-a-long-random-secret

# After setting SMTP_USER/SMTP_PASS, write the account file the compose mounts:
#   printf '%s:%s\n' "$SMTP_USER" "$SMTP_PASS" > sasl_accounts
