rules_version = '2';

// MarketWar OS Firestore rules — deny by default.
// Server-side writes (Next.js API routes on Vercel via the Admin SDK) bypass
// these rules; they govern direct client access only. As client features
// (auth, real-time dashboards) come online, open access per-collection with
// owner checks — never with a blanket allow.
service cloud.firestore {
  match /databases/{database}/documents {

    // Tenant-scoped data: a signed-in user may only touch their own tenant.
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.tenantId == tenantId;
    }

    // users (v3.0 spec 6.2.1): owner-only reads. All writes go through
    // backend services via the Admin SDK (auth/billing/MOA), so client
    // writes are denied entirely — enforcing "write: service only".
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // businesses (v3.0 spec 6.2.2): owner full access; agency admins of the
    // same agency may read. BVI/diagnostic fields are service-written.
    match /businesses/{businessId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.token.role == 'agency_admin');
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Server-written analytics/logs: clients may never read or write.
    match /audits/{doc} {
      allow read, write: if false;
    }
    match /agent_runs/{doc} {
      allow read, write: if false;
    }
    // Attributed-revenue ledger (results): written ONLY by the Admin SDK
    // (manual log, owned-form capture, Stripe webhook). No client access — the
    // dashboard reads via /api/results, which is server-side. Append-only in
    // spirit; the id is the source event id so redelivery never double-counts.
    match /results/{doc} {
      allow read, write: if false;
    }

    // ── ModelGate / commercial core (production architecture §20, §22, §35) ──
    // The client may READ authorised business data but must NEVER directly
    // modify balances, costs, subscriptions, model pricing, margins, security
    // or audit history — those writes occur only through trusted Admin SDK
    // operations (rule #17: block direct balance manipulation).
    function isOrgMember(orgId) {
      return request.auth != null && request.auth.token.organisationId == orgId;
    }

    // ACU ledger + wallets: organisation members read; writes are server-only.
    match /acuWallets/{walletId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /acuTransactions/{txId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false; // append-only ledger, Admin SDK only
    }
    match /acuReservations/{resId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    // AI jobs + generated assets: org members read their own; writes server-only.
    match /aiJobs/{jobId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /generatedAssets/{assetId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    // Subscriptions + billing events: read own org; writes only via Stripe
    // webhook / Admin SDK (never the client).
    match /subscriptions/{subId} {
      allow read: if isOrgMember(resource.data.organisationId);
      allow write: if false;
    }
    match /billingEvents/{evId} {
      allow read, write: if false; // server-only
    }
    // Model registry + provider health/pricing: public-readable catalogue
    // (no secrets, no prices client-side), admin-written only.
    match /providerModels/{modelId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /providerHealth/{providerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Margins, provider costs, security + audit: never client-accessible.
    match /marginRecords/{doc} { allow read, write: if false; }
    match /providerUsage/{doc} { allow read, write: if false; }
    match /providerCosts/{doc} { allow read, write: if false; }
    match /securityEvents/{doc} { allow read, write: if false; }
    match /auditLogs/{doc} { allow read, write: if false; }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
